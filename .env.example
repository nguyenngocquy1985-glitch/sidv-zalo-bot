# ── Chạy trên máy tính cá nhân ────────────────────────────────────────────
# Chỉ cần SHEETS_URL. cookies.json được tạo tự động từ login.js

# URL của Google Apps Script Web App (lấy từ tracker ⚙️ → copy URL)
SHEETS_URL=https://script.google.com/macros/s/ABC.../exec


# ── Chạy trên Railway / server ────────────────────────────────────────────
# Thêm 2 biến này trong Railway Dashboard → Variables

# Session Zalo (base64 của cookies.json, tạo bởi login.js)
ZALO_COOKIES=

# URL của Google Apps Script Web App
SHEETS_URL=https://script.google.com/macros/s/ABC.../exec
